# Copy to `.env` and fill in your local values.

# Database (create with db/sql/01_create_database.sql in PGAdmin).
# Attach the connection under your PGAdmin server group "Guilds of Ardessia".
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/guilds_of_ardessia

# Better Auth — generate with: openssl rand -base64 32
# Must be at least 32 characters.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Public base URL of this app (match the port Vite actually serves).
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Cloudflare R2 (hero portraits, equipment art)
# Bucket: guilds-of-ardessia
# Public layout:
#   hero-portraits/Sigurd_Warrior.png
#   hero-portraits/Lyra_Rogue.png
#   hero-portraits/Kaeleen_Mage.png
#   hero-portraits/Sariel_Cleric.png
#   equipment/… (later)
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=guilds-of-ardessia

# Public CDN base for the bucket (R2 → Settings → Public access → r2.dev URL,
# or a custom domain). No trailing slash.
# Vite exposes VITE_* to the browser — keep both values identical.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
VITE_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
