# Copy to `.env` and fill in your local values.

# Database (create with db/sql/01_create_database.sql in PGAdmin).
# Attach the connection under your PGAdmin server group "Guilds of Ardessia".
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/guilds_of_ardessia

# Better Auth — generate with: openssl rand -base64 32
# Must be at least 32 characters.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Public base URL of this app (match the port Vite actually serves).
BETTER_AUTH_URL=http://localhost:3000
